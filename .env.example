# --- Runtime ---
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
PUBLIC_URL=http://localhost:3000

# --- Database / Cache ---
DATABASE_URL=postgres://vkbot:vkbot@localhost:5432/vkbot
REDIS_URL=redis://localhost:6379

# --- OpenRouter ---
OPENROUTER_API_KEY=sk-or-v1-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- VK API ---
VK_API_VERSION=5.199

# --- Crypto ---
# Generate via: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# --- Auth ---
JWT_SECRET=replace-with-long-random-string
ADMIN_LOGIN=admin
# Generate via: node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash

# --- Compose-only ---
POSTGRES_USER=vkbot
POSTGRES_PASSWORD=vkbot
POSTGRES_DB=vkbot
