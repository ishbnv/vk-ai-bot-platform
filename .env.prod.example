# ============ PRODUCTION — vk.24finkit.ru ============
# Кладётся на сервер как .env.prod рядом с docker-compose.deploy.yml.
# docker compose -f docker-compose.deploy.yml --env-file .env.prod up -d --build

# Изоляция стэка — отдельные volumes/network с этим префиксом
COMPOSE_PROJECT_NAME=vk-ai-bot-prod

# Какой порт backend пробрасывает на хост → должен совпадать с proxy_pass в nginx-конфиге
BACKEND_HOST_PORT=3032

NODE_ENV=production
LOG_LEVEL=info
PORT=3000
PUBLIC_URL=https://vk.24finkit.ru

POSTGRES_USER=vkbot
POSTGRES_PASSWORD=replace-strong-random
POSTGRES_DB=vkbot

# Внутри docker-сети
DATABASE_URL=postgres://vkbot:replace-strong-random@postgres:5432/vkbot
REDIS_URL=redis://redis:6379

OPENROUTER_API_KEY=sk-or-v1-replace-with-prod-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

VK_API_VERSION=5.199

# openssl rand -hex 32  (64 hex-символа)
ENCRYPTION_KEY=replace-with-32-byte-hex-string

# openssl rand -base64 48 — секрет для подписи JWT (минимум 32 байта)
JWT_SECRET=replace-with-long-random-string-min-32-chars

ADMIN_LOGIN=admin
# node -e "console.log(require('bcryptjs').hashSync('your-prod-password', 12))"
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash
