# ============ DEV ON VPS — vk.dev.24finkit.ru ============
# Кладётся на сервер как .env.dev рядом с docker-compose.deploy.yml.
# docker compose -f docker-compose.deploy.yml --env-file .env.dev up -d --build
#
# ВАЖНО: все секреты должны быть РАЗНЫЕ от prod — отдельные хэши, отдельный ENCRYPTION_KEY.
# Если переиспользуешь prod-ключ в dev и его сольёт — расшифровать токены сообществ можно.

COMPOSE_PROJECT_NAME=vk-ai-bot-dev
BACKEND_HOST_PORT=3042

NODE_ENV=production
LOG_LEVEL=debug
PORT=3000
PUBLIC_URL=https://vk.dev.24finkit.ru

POSTGRES_USER=vkbot
POSTGRES_PASSWORD=replace-dev-random
POSTGRES_DB=vkbot

DATABASE_URL=postgres://vkbot:replace-dev-random@postgres:5432/vkbot
REDIS_URL=redis://redis:6379

OPENROUTER_API_KEY=sk-or-v1-replace-with-dev-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

VK_API_VERSION=5.199

ENCRYPTION_KEY=replace-with-separate-32-byte-hex-string
JWT_SECRET=replace-with-separate-long-random-string

ADMIN_LOGIN=admin
ADMIN_PASSWORD_HASH=replace-with-bcrypt-hash-for-dev
